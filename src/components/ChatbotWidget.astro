---
// ChatbotWidget.astro — Aurora Chatbot de Contacto
// Forja Labs · Azul #3B58B8 · Dorado accent
---

<!-- FAB Button -->
<button
  id="chatbot-fab"
  class="chatbot-fab"
  aria-label="Abrir chat de contacto"
  aria-expanded="false"
>
  <span class="material-icons fab-icon-open">chat</span>
  <span class="material-icons fab-icon-close">close</span>
</button>

<!-- Chat Widget -->
<div id="chatbot-widget" class="chatbot-widget" role="dialog" aria-label="Chat de contacto Forja Labs">
  <!-- Header -->
  <div class="chat-header">
    <div class="chat-header-info">
      <div class="chat-avatar">
        <span class="material-icons">smart_toy</span>
      </div>
      <div>
        <p class="chat-header-name">Aurora</p>
        <p class="chat-header-status"><span class="status-dot"></span> En línea</p>
      </div>
    </div>
    <button id="chatbot-close" class="chat-close-btn" aria-label="Cerrar chat">
      <span class="material-icons">close</span>
    </button>
  </div>

  <!-- Messages -->
  <div id="chatbot-messages" class="chat-messages" aria-live="polite"></div>

  <!-- Input area -->
  <div id="chatbot-input-area" class="chat-input-area"></div>
</div>

<script src="../scripts/chatbot.js"></script>

<style>
  /* ── Variables ─────────────────────────────────────────────── */
  :root {
    --forja-blue: #3B58B8;
    --forja-blue-dark: #2d4494;
    --forja-blue-light: #5a76d4;
    --forja-gold: #f59e0b;
    --forja-gold-hover: #fbbf24;
    --chat-bot-bubble: #1e3a8a1a;
    --chat-bot-bubble-border: #3B58B820;
    --chat-user-bubble: #2a2a2a;
    --chat-bg: #0d0d0d;
    --chat-header-bg: #3B58B8;
    --chat-input-bg: #141414;
    --radius: 18px;
    --radius-sm: 10px;
  }

  /* ── FAB ───────────────────────────────────────────────────── */
  .chatbot-fab {
    position: fixed;
    bottom: 1.75rem;
    right: 1.75rem;
    z-index: 9998;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: var(--forja-blue);
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(59, 88, 184, 0.45);
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    overflow: hidden;
  }

  .chatbot-fab:hover {
    background: var(--forja-gold);
    transform: scale(1.08);
    box-shadow: 0 6px 28px rgba(245, 158, 11, 0.4);
  }

  .chatbot-fab .material-icons {
    font-size: 1.6rem;
    position: absolute;
    transition: opacity 0.2s ease, transform 0.25s ease;
  }

  .chatbot-fab .fab-icon-open  { opacity: 1; transform: rotate(0deg); }
  .chatbot-fab .fab-icon-close { opacity: 0; transform: rotate(-90deg); }

  /* When chat is open, swap icons */
  .chatbot-fab[aria-expanded="true"] .fab-icon-open  { opacity: 0; transform: rotate(90deg); }
  .chatbot-fab[aria-expanded="true"] .fab-icon-close { opacity: 1; transform: rotate(0deg); }

  .chatbot-fab.already-contacted::after {
    content: '✓';
    position: absolute;
    bottom: 2px;
    right: 2px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #22c55e;
    font-size: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 700;
    line-height: 1;
  }

  /* ── Widget ────────────────────────────────────────────────── */
  .chatbot-widget {
    position: fixed;
    bottom: calc(1.75rem + 58px + 12px);
    right: 1.75rem;
    z-index: 9997;
    width: 350px;
    height: 500px;
    background: var(--chat-bg);
    border: 1px solid #242424;
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
    overflow: hidden;

    /* Hidden by default */
    opacity: 0;
    transform: translateY(12px) scale(0.97);
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .chatbot-widget.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: all;
  }

  /* ── Header ────────────────────────────────────────────────── */
  .chat-header {
    background: var(--forja-blue);
    padding: 0.85rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }

  .chat-header-info {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .chat-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .chat-avatar .material-icons {
    color: #fff;
    font-size: 1.2rem;
  }

  .chat-header-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: #fff;
    line-height: 1;
  }

  .chat-header-status {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.75);
    margin-top: 2px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .status-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 4px #4ade80aa;
  }

  .chat-close-btn {
    background: none;
    border: none;
    color: rgba(255,255,255,0.8);
    cursor: pointer;
    padding: 4px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  .chat-close-btn:hover {
    background: rgba(255,255,255,0.15);
    color: #fff;
  }

  .chat-close-btn .material-icons {
    font-size: 1.2rem;
  }

  /* ── Messages ──────────────────────────────────────────────── */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    scroll-behavior: smooth;
  }

  .chat-messages::-webkit-scrollbar {
    width: 4px;
  }

  .chat-messages::-webkit-scrollbar-thumb {
    background: #333;
    border-radius: 2px;
  }

  :global(.chat-msg) {
    display: flex;
    max-width: 88%;
  }

  :global(.chat-msg.bot) {
    align-self: flex-start;
  }

  :global(.chat-msg.user) {
    align-self: flex-end;
  }

  :global(.chat-msg .msg-bubble) {
    padding: 0.6rem 0.9rem;
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    line-height: 1.5;
    word-break: break-word;
  }

  :global(.chat-msg.bot .msg-bubble) {
    background: rgba(59, 88, 184, 0.12);
    border: 1px solid rgba(59, 88, 184, 0.2);
    color: #e0e8ff;
    border-bottom-left-radius: 4px;
  }

  :global(.chat-msg.user .msg-bubble) {
    background: var(--chat-user-bubble);
    color: #e0e0e0;
    border-bottom-right-radius: 4px;
  }

  /* Typing indicator */
  :global(.typing-indicator .msg-bubble) {
    display: flex;
    gap: 4px;
    align-items: center;
    padding: 0.65rem 0.9rem;
  }

  :global(.typing-indicator span) {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--forja-blue-light);
    animation: bounce 1s infinite ease-in-out;
  }

  :global(.typing-indicator span:nth-child(2)) { animation-delay: 0.18s; }
  :global(.typing-indicator span:nth-child(3)) { animation-delay: 0.36s; }

  @keyframes bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-5px); }
  }

  /* ── Input Area ────────────────────────────────────────────── */
  .chat-input-area {
    border-top: 1px solid #1e1e1e;
    padding: 0.75rem;
    background: var(--chat-input-bg);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Button groups */
  :global(.chat-btn-group) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  :global(.chat-btn-group.column) {
    flex-direction: column;
  }

  :global(.chat-btn) {
    padding: 0.5rem 0.85rem;
    border-radius: 8px;
    background: var(--forja-blue);
    color: #fff;
    border: none;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.18s ease, transform 0.15s ease;
    text-align: center;
  }

  :global(.chat-btn:hover) {
    background: var(--forja-gold);
    color: #000;
    transform: translateY(-1px);
  }

  :global(.chat-btn.whatsapp-btn) {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #25D366;
    color: #fff;
    text-decoration: none;
    padding: 0.65rem 1rem;
    font-size: 0.88rem;
  }

  :global(.chat-btn.whatsapp-btn:hover) {
    background: #1da853;
    color: #fff;
  }

  :global(.chat-btn.secondary-btn) {
    background: transparent;
    border: 1px solid #333;
    color: #888;
    font-size: 0.78rem;
  }

  :global(.chat-btn.secondary-btn:hover) {
    background: #1e1e1e;
    color: #ccc;
    transform: none;
  }

  /* Text input row */
  :global(.chat-input-wrap) {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  :global(.chat-textarea-wrap) {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  :global(.chat-text-input) {
    flex: 1;
    background: #1a1a1a;
    border: 1px solid #2e2e2e;
    border-radius: 8px;
    color: #f0f0f0;
    font-family: inherit;
    font-size: 0.85rem;
    padding: 0.5rem 0.75rem;
    outline: none;
    transition: border-color 0.15s;
    resize: none;
  }

  :global(.chat-text-input:focus) {
    border-color: var(--forja-blue);
  }

  :global(.chat-text-input.error) {
    border-color: #ef4444;
  }

  :global(.chat-text-input.textarea) {
    width: 100%;
    min-height: 70px;
  }

  :global(.chat-send-btn) {
    background: var(--forja-blue);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0.5rem 0.6rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.18s;
    flex-shrink: 0;
  }

  :global(.chat-send-btn:hover) {
    background: var(--forja-gold);
    color: #000;
  }

  :global(.chat-send-btn.full) {
    width: 100%;
    padding: 0.55rem;
    font-size: 0.85rem;
    font-weight: 600;
    font-family: inherit;
    gap: 4px;
  }

  :global(.chat-send-btn .material-icons) {
    font-size: 1.1rem;
  }

  :global(.chat-skip-btn) {
    background: none;
    border: none;
    color: #666;
    font-size: 0.75rem;
    cursor: pointer;
    text-align: right;
    padding: 0;
    transition: color 0.15s;
    font-family: inherit;
  }

  :global(.chat-skip-btn:hover) {
    color: var(--forja-gold);
  }

  :global(.chat-error) {
    color: #ef4444;
    font-size: 0.75rem;
    margin: 0;
    padding: 0 0.1rem;
  }

  /* ── Responsive Mobile ─────────────────────────────────────── */
  @media (max-width: 480px) {
    .chatbot-widget {
      width: calc(100vw - 1rem);
      right: 0.5rem;
      left: 0.5rem;
      bottom: calc(58px + 1.25rem);
      height: 460px;
      border-radius: 14px;
    }

    .chatbot-fab {
      bottom: 1.25rem;
      right: 1.25rem;
    }
  }
</style>
