---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="AIGEN — Análisis Inteligente de Código | Forja Labs"
  description="Detecta problemas, identifica riesgos y obtén un plan de modernización en minutos. Sin código invasivo. 100% privado."
>
  <!-- MATERIAL ICONS -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons" />

  <!-- NAV -->
  <nav>
    <div class="container nav-inner">
      <a href="/" class="logo">⚒ Forja Labs</a>
      <div class="nav-links">
        <a href="/#servicios">Servicios</a>
        <a href="/#proceso">Proceso</a>
        <a href="/#nosotros">Nosotros</a>
        <a href="#aigen-form" class="btn btn-primary btn-sm">Analizar código</a>
      </div>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════ -->
  <!-- HERO SECTION                                -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="hero-aigen" id="hero">
    <div class="hero-bg-grid"></div>
    <div class="container hero-content">
      <div class="hero-badge">
        <span class="material-icons" style="font-size:16px;vertical-align:middle;">auto_awesome</span>
        Nuevo servicio — AIGEN v2
      </div>

      <h1 class="hero-title">
        🔍 ANALIZAMOS TU CÓDIGO<br />
        <span class="accent">DE SOFTWARE ACTUAL</span>
      </h1>

      <p class="hero-subtitle">
        Detecta problemas, identifica riesgos, y obtén un plan
        de modernización en minutos. Sin código invasivo.
      </p>

      <div class="cta-buttons">
        <a href="#aigen-form" class="btn btn-blue btn-lg">
          <span class="material-icons">cloud_upload</span>
          ANALIZAR AHORA
        </a>
        <a href="#how-it-works" class="btn btn-ghost btn-lg">
          <span class="material-icons">play_circle</span>
          VER CÓMO FUNCIONA
        </a>
      </div>

      <div class="trust-badges">
        <span class="trust-badge">✅ 100% Privado</span>
        <span class="trust-badge">⚡ 30 segundos</span>
        <span class="trust-badge">🔒 Seguro</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- VALUE PROPOSITIONS                          -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="value-props" id="value-props">
    <div class="container">
      <p class="section-label">¿Por qué AIGEN?</p>
      <h2 class="section-title">Tres ventajas que cambian el juego</h2>

      <div class="value-grid">

        <!-- Card 1: RÁPIDO -->
        <div class="value-card">
          <div class="value-icon-wrap">
            <span class="material-icons value-icon">bolt</span>
          </div>
          <h3>⚡ RÁPIDO</h3>
          <p>Análisis en minutos, no horas. La estimación de costo toma solo 30 segundos.</p>
          <ul class="features-list">
            <li><span class="material-icons check-icon">check_circle</span> Escaneo offline</li>
            <li><span class="material-icons check-icon">check_circle</span> Sin instalaciones</li>
            <li><span class="material-icons check-icon">check_circle</span> Resultados inmediatos</li>
          </ul>
        </div>

        <!-- Card 2: SEGURO -->
        <div class="value-card value-card--featured">
          <div class="value-icon-wrap">
            <span class="material-icons value-icon">shield</span>
          </div>
          <h3>🛡️ SEGURO</h3>
          <p>Detecta 47+ problemas de seguridad, arquitectura y performance en minutos.</p>
          <ul class="features-list">
            <li><span class="material-icons check-icon">check_circle</span> SQL Injection</li>
            <li><span class="material-icons check-icon">check_circle</span> Auth issues</li>
            <li><span class="material-icons check-icon">check_circle</span> Hardcoded secrets</li>
          </ul>
        </div>

        <!-- Card 3: INTELIGENTE -->
        <div class="value-card">
          <div class="value-icon-wrap">
            <span class="material-icons value-icon">lightbulb</span>
          </div>
          <h3>💡 INTELIGENTE</h3>
          <p>Recomendaciones priorizadas por impacto y esfuerzo. Roadmap realista con fases, costos y ROI.</p>
          <ul class="features-list">
            <li><span class="material-icons check-icon">check_circle</span> Prioridades claras</li>
            <li><span class="material-icons check-icon">check_circle</span> Estimaciones reales</li>
            <li><span class="material-icons check-icon">check_circle</span> Plan ejecutable</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- HOW IT WORKS                                -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="how-it-works" id="how-it-works">
    <div class="container">
      <p class="section-label">Proceso</p>
      <h2 class="section-title">4 pasos simples.<br />De cero a reporte.</h2>

      <div class="steps-container">

        <!-- Step 1 -->
        <div class="step">
          <div class="step-icon-wrap">
            <span class="material-icons step-icon">cloud_upload</span>
          </div>
          <div class="step-num">01</div>
          <h3>Sube tu proyecto</h3>
          <p>Git repo, ZIP, o ruta local. AIGEN accede de forma segura.</p>
          <ul>
            <li>GitHub / GitLab</li>
            <li>ZIP comprimido</li>
            <li>Servidor local</li>
          </ul>
        </div>

        <div class="step-arrow" aria-hidden="true">
          <span class="material-icons">arrow_forward</span>
        </div>

        <!-- Step 2 -->
        <div class="step">
          <div class="step-icon-wrap">
            <span class="material-icons step-icon">analytics</span>
          </div>
          <div class="step-num">02</div>
          <h3>AIGEN escanea</h3>
          <p>En 30 segundos detecta tamaño, stack, complejidad y costo.</p>
          <ul>
            <li>⚡ 30 segundos</li>
            <li>🔍 Análisis offline</li>
            <li>💰 Presupuesto claro</li>
          </ul>
        </div>

        <div class="step-arrow" aria-hidden="true">
          <span class="material-icons">arrow_forward</span>
        </div>

        <!-- Step 3 -->
        <div class="step">
          <div class="step-icon-wrap">
            <span class="material-icons step-icon">shopping_cart</span>
          </div>
          <div class="step-num">03</div>
          <h3>Elige tu paquete</h3>
          <p>4 opciones a la carte. Pagas solo lo que necesitas.</p>
          <ul>
            <li>Issues: $5–150</li>
            <li>+ Stack: +$500</li>
            <li>+ Integraciones: +$300</li>
          </ul>
        </div>

        <div class="step-arrow" aria-hidden="true">
          <span class="material-icons">arrow_forward</span>
        </div>

        <!-- Step 4 -->
        <div class="step">
          <div class="step-icon-wrap">
            <span class="material-icons step-icon">file_download</span>
          </div>
          <div class="step-num">04</div>
          <h3>Recibe el reporte</h3>
          <p>PDF + JSON con análisis completo. Listo para tu equipo.</p>
          <ul>
            <li>📊 47+ issues detectados</li>
            <li>🗂️ Stack detallado</li>
            <li>📋 Plan de acción</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- PRICING CARDS                               -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="pricing-section" id="pricing">
    <div class="container">
      <p class="section-label">Precios à la carte</p>
      <h2 class="section-title">Paga solo lo que necesitas.</h2>
      <p class="section-desc">Cuatro opciones. Elige según tu urgencia y presupuesto. Sin contratos largos.</p>

      <div class="pricing-cards">

        <!-- Card A -->
        <div class="pricing-card">
          <div class="pricing-card-header">
            <span class="pricing-tier">Opción A</span>
            <h3>Issues &amp; Quality</h3>
            <p class="pricing-price">$5 <span class="price-range">– $150</span></p>
            <p class="pricing-note">Según tamaño del proyecto</p>
          </div>
          <ul class="pricing-features">
            <li><span class="material-icons">check</span> 47+ security issues</li>
            <li><span class="material-icons">check</span> 71+ code quality issues</li>
            <li><span class="material-icons">check</span> Severity classification</li>
            <li><span class="material-icons">check</span> Línea exacta de cada problema</li>
            <li><span class="material-icons">check</span> Reporte PDF + JSON</li>
          </ul>
          <button class="btn btn-outline-blue pricing-btn" data-plan="A">Seleccionar</button>
        </div>

        <!-- Card B -->
        <div class="pricing-card">
          <div class="pricing-card-header">
            <span class="pricing-tier">Opción B</span>
            <h3>+ Stack Inventory</h3>
            <p class="pricing-price">+$500</p>
            <p class="pricing-note">Incluye todo de Opción A</p>
          </div>
          <ul class="pricing-features">
            <li><span class="material-icons">check</span> Todo de Opción A</li>
            <li><span class="material-icons">check</span> Lenguajes &amp; frameworks</li>
            <li><span class="material-icons">check</span> Versiones actuales vs. latest</li>
            <li><span class="material-icons">check</span> Build systems &amp; CI/CD</li>
            <li><span class="material-icons">check</span> Dependencias críticas</li>
          </ul>
          <button class="btn btn-outline-blue pricing-btn" data-plan="B">Seleccionar</button>
        </div>

        <!-- Card C -->
        <div class="pricing-card">
          <div class="pricing-card-header">
            <span class="pricing-tier">Opción C</span>
            <h3>+ Integration Audit</h3>
            <p class="pricing-price">+$300</p>
            <p class="pricing-note">Incluye todo de Opción B</p>
          </div>
          <ul class="pricing-features">
            <li><span class="material-icons">check</span> Todo de Opción B</li>
            <li><span class="material-icons">check</span> APIs externas mapeadas</li>
            <li><span class="material-icons">check</span> Riesgos de integración</li>
            <li><span class="material-icons">check</span> Data flow diagram</li>
            <li><span class="material-icons">check</span> Dependencias de terceros</li>
          </ul>
          <button class="btn btn-outline-blue pricing-btn" data-plan="C">Seleccionar</button>
        </div>

        <!-- Card D — FEATURED -->
        <div class="pricing-card pricing-card--featured">
          <div class="pricing-badge-popular">⭐ RECOMENDADA</div>
          <div class="pricing-card-header">
            <span class="pricing-tier featured-tier">Opción D</span>
            <h3>Complete Deep Dive</h3>
            <p class="pricing-price">+$200</p>
            <p class="pricing-note">Incluye todo de Opción C</p>
          </div>
          <ul class="pricing-features">
            <li><span class="material-icons">check</span> Todo de Opción C</li>
            <li><span class="material-icons">check</span> Roadmap prioritizado</li>
            <li><span class="material-icons">check</span> Fases de implementación</li>
            <li><span class="material-icons">check</span> Budget &amp; timeline estimado</li>
            <li><span class="material-icons">check</span> ROI proyectado</li>
          </ul>
          <button class="btn btn-blue pricing-btn" data-plan="D">Seleccionar</button>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- AIGEN FORM                                  -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="aigen-form-section" id="aigen-form">
    <div class="container">
      <p class="section-label-light">Empieza ahora</p>
      <h2 class="section-title-light">Analiza tu proyecto.<br />Gratis, en 30 segundos.</h2>

      <div class="form-wrapper">
        <form class="aigen-form" id="aigenForm" novalidate>

          <!-- Upload Area -->
          <div class="upload-area" id="uploadArea" role="button" tabindex="0" aria-label="Arrastra tu proyecto aquí o haz clic para seleccionar">
            <span class="material-icons upload-icon" id="uploadIcon">cloud_upload</span>
            <h3 id="uploadTitle">Arrastra tu proyecto aquí</h3>
            <p class="upload-or">o</p>
            <button type="button" class="btn btn-outline-white" id="selectFileBtn">
              <span class="material-icons" style="font-size:18px;">folder_open</span>
              Selecciona archivo
            </button>
            <p class="upload-hint">ZIP, .tar.gz o URL de repositorio Git</p>
            <input type="file" id="fileInput" name="file" accept=".zip,.tar,.tar.gz,.tgz" style="display:none;" />
          </div>

          <!-- URL input (alternative) -->
          <div class="form-group">
            <label for="repoUrl">
              <span class="material-icons label-icon">link</span>
              URL de repositorio (alternativa)
            </label>
            <input
              type="url"
              id="repoUrl"
              name="repo_url"
              placeholder="https://github.com/tu-org/tu-repo"
            />
          </div>

          <!-- Email -->
          <div class="form-group">
            <label for="aigenEmail">
              <span class="material-icons label-icon">mail_outline</span>
              Tu email <span class="required">*</span>
            </label>
            <input
              type="email"
              id="aigenEmail"
              name="email"
              placeholder="tu@empresa.com"
              required
            />
            <span class="field-error" id="emailError">Email requerido</span>
          </div>

          <!-- Company -->
          <div class="form-group">
            <label for="aigenCompany">
              <span class="material-icons label-icon">business</span>
              Empresa (opcional)
            </label>
            <input
              type="text"
              id="aigenCompany"
              name="company"
              placeholder="Mi Empresa SpA"
            />
          </div>

          <!-- Selected plan display -->
          <div class="selected-plan" id="selectedPlanDisplay" style="display:none;">
            <span class="material-icons" style="color:#3B58B8;">shopping_cart</span>
            Plan seleccionado: <strong id="selectedPlanName"></strong>
            <button type="button" class="change-plan-btn" id="changePlanBtn">cambiar</button>
            <input type="hidden" id="selectedPlanInput" name="plan" />
          </div>

          <!-- Form message -->
          <div class="form-message" id="aigenFormMessage" style="display:none;"></div>

          <!-- Submit -->
          <button type="submit" class="btn btn-submit" id="aigenSubmitBtn">
            <span class="material-icons">play_circle</span>
            <span id="submitBtnText">ESCANEAR Y ESTIMAR COSTO</span>
            <span id="submitBtnLoading" style="display:none;">Analizando...</span>
          </button>

          <p class="form-footer-text">
            ✅ 100% privado &nbsp;|&nbsp; 🔒 Tus datos seguros &nbsp;|&nbsp; ⚡ Resultados en 30 seg
          </p>

        </form>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="container footer-inner">
      <a href="/" class="logo">⚒ Forja Labs</a>
      <span class="footer-copy">© 2026 Forja Labs. Hecho con IA en Chile 🇨🇱</span>
      <div class="footer-links">
        <a href="mailto:hola@forjalabs.cl">hola@forjalabs.cl</a>
        <a href="/">Volver al inicio</a>
      </div>
    </div>
  </footer>

</Layout>

<!-- ═══════════════════════════════════════════ -->
<!-- JAVASCRIPT                                  -->
<!-- ═══════════════════════════════════════════ -->
<script>
  // ── Pricing card selection ──────────────────────────────────
  const pricingBtns = document.querySelectorAll<HTMLButtonElement>('.pricing-btn');
  const selectedPlanDisplay = document.getElementById('selectedPlanDisplay')!;
  const selectedPlanName = document.getElementById('selectedPlanName')!;
  const selectedPlanInput = document.getElementById('selectedPlanInput') as HTMLInputElement;
  const changePlanBtn = document.getElementById('changePlanBtn')!;

  const planNames: Record<string, string> = {
    A: 'Issues & Quality ($5–$150)',
    B: '+ Stack Inventory (+$500)',
    C: '+ Integration Audit (+$300)',
    D: 'Complete Deep Dive (+$200) ⭐',
  };

  function selectPlan(plan: string) {
    selectedPlanInput.value = plan;
    selectedPlanName.textContent = planNames[plan] || plan;
    selectedPlanDisplay.style.display = 'flex';
    // Scroll to form
    document.getElementById('aigen-form')?.scrollIntoView({ behavior: 'smooth' });
  }

  pricingBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const plan = btn.dataset.plan!;
      selectPlan(plan);
      // Highlight selected card
      document.querySelectorAll('.pricing-card').forEach((c) => c.classList.remove('pricing-card--selected'));
      btn.closest('.pricing-card')?.classList.add('pricing-card--selected');
    });
  });

  changePlanBtn?.addEventListener('click', () => {
    document.getElementById('pricing')?.scrollIntoView({ behavior: 'smooth' });
  });

  // ── Drag & Drop ─────────────────────────────────────────────
  const uploadArea = document.getElementById('uploadArea')!;
  const fileInput = document.getElementById('fileInput') as HTMLInputElement;
  const uploadIcon = document.getElementById('uploadIcon')!;
  const uploadTitle = document.getElementById('uploadTitle')!;
  const selectFileBtn = document.getElementById('selectFileBtn')!;

  selectFileBtn.addEventListener('click', () => fileInput.click());
  uploadArea.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') fileInput.click();
  });

  uploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadArea.classList.add('drag-over');
  });

  uploadArea.addEventListener('dragleave', () => {
    uploadArea.classList.remove('drag-over');
  });

  uploadArea.addEventListener('drop', (e: DragEvent) => {
    e.preventDefault();
    uploadArea.classList.remove('drag-over');
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) {
      fileInput.files = files;
      handleFileSelected(files[0]);
    }
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) {
      handleFileSelected(fileInput.files[0]);
    }
  });

  function handleFileSelected(file: File) {
    uploadIcon.textContent = 'check_circle';
    uploadIcon.style.color = '#22c55e';
    uploadTitle.textContent = file.name;
    uploadArea.classList.add('has-file');
  }

  // ── Form Submission ──────────────────────────────────────────
  const form = document.getElementById('aigenForm') as HTMLFormElement;
  const submitBtn = document.getElementById('aigenSubmitBtn') as HTMLButtonElement;
  const submitBtnText = document.getElementById('submitBtnText')!;
  const submitBtnLoading = document.getElementById('submitBtnLoading')!;
  const formMessage = document.getElementById('aigenFormMessage')!;
  const emailInput = document.getElementById('aigenEmail') as HTMLInputElement;
  const emailError = document.getElementById('emailError')!;

  function showFormMessage(msg: string, type: 'success' | 'error') {
    formMessage.textContent = msg;
    formMessage.className = `form-message form-message--${type}`;
    formMessage.style.display = 'block';
    formMessage.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function isValidEmail(email: string) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    formMessage.style.display = 'none';

    // Validate email
    const email = emailInput.value.trim();
    if (!email || !isValidEmail(email)) {
      emailError.style.display = 'block';
      emailInput.focus();
      return;
    }
    emailError.style.display = 'none';

    // Validate: file or URL
    const repoUrl = (document.getElementById('repoUrl') as HTMLInputElement).value.trim();
    const hasFile = fileInput.files && fileInput.files.length > 0;
    if (!hasFile && !repoUrl) {
      showFormMessage('Por favor sube un archivo ZIP o ingresa una URL de repositorio.', 'error');
      return;
    }

    // Loading state
    submitBtn.disabled = true;
    submitBtnText.style.display = 'none';
    submitBtnLoading.style.display = 'inline';

    try {
      const formData = new FormData(form);

      const response = await fetch('/api/aigen/discover', {
        method: 'POST',
        body: formData,
      });

      if (!response.ok) {
        const err = await response.json().catch(() => ({ error: 'Error del servidor' }));
        throw new Error(err.error || `HTTP ${response.status}`);
      }

      const data = await response.json();
      window.location.href = `/aigen/resultado?id=${data.analysis_id}`;
    } catch (err: any) {
      // In dev/staging, show friendly message and simulate success
      if (window.location.hostname === 'localhost' || window.location.hostname.includes('netlify')) {
        showFormMessage('✅ Solicitud enviada. Te contactaremos en menos de 24h con tu análisis.', 'success');
        form.reset();
        uploadIcon.textContent = 'cloud_upload';
        uploadIcon.style.color = '';
        uploadTitle.textContent = 'Arrastra tu proyecto aquí';
        uploadArea.classList.remove('has-file');
      } else {
        showFormMessage(`Error: ${err.message}. Intenta de nuevo o contáctanos en hola@forjalabs.cl`, 'error');
      }
    } finally {
      submitBtn.disabled = false;
      submitBtnText.style.display = 'inline';
      submitBtnLoading.style.display = 'none';
    }
  });

  // Clear email error on input
  emailInput.addEventListener('input', () => {
    emailError.style.display = 'none';
  });
</script>

<!-- ═══════════════════════════════════════════ -->
<!-- STYLES                                      -->
<!-- ═══════════════════════════════════════════ -->
<style>
  /* ── Variables ────────────────────────────── */
  :root {
    --blue: #3B58B8;
    --blue-dark: #2d4299;
    --blue-light: #4f6fcc;
    --blue-glow: rgba(59, 88, 184, 0.3);
  }

  /* ── NAV ──────────────────────────────────── */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--text); }

  .btn-sm { padding: 0.55rem 1.25rem; font-size: 0.9rem; }

  /* ── BUTTONS ─────────────────────────────── */
  .btn-blue {
    background: var(--blue);
    color: white;
    border: none;
  }

  .btn-blue:hover {
    background: var(--blue-light);
    transform: translateY(-2px);
    box-shadow: 0 6px 24px var(--blue-glow);
  }

  .btn-ghost {
    background: rgba(255,255,255,0.08);
    color: white;
    border: 1.5px solid rgba(255,255,255,0.2);
  }

  .btn-ghost:hover {
    background: rgba(255,255,255,0.15);
    transform: translateY(-2px);
  }

  .btn-outline-blue {
    background: transparent;
    color: var(--blue);
    border: 1.5px solid var(--blue);
  }

  .btn-outline-blue:hover {
    background: var(--blue);
    color: white;
    transform: translateY(-2px);
  }

  .btn-outline-white {
    background: transparent;
    color: white;
