---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- NAV -->
  <nav>
    <div class="container nav-inner">
      <a href="/" class="logo">⚒ Forja Labs</a>
      <div class="nav-links">
        <a href="#servicios">Servicios</a>
        <a href="#proceso">Proceso</a>
        <a href="#nosotros">Nosotros</a>
        <a href="#contacto" class="btn btn-primary btn-sm">Solicita ahora</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section id="hero">
    <div class="container hero-inner">
      <div class="hero-badge">🚀 Software + AI = velocidad real</div>
      <h1>
        Tu software a medida,<br />
        <span class="accent">listo en 2-3 semanas.</span>
      </h1>
      <p class="hero-desc">
        No más proyectos que duran meses. Forja Labs construye soluciones reales
        con un equipo de agentes AI especializados — rápido, sin burocracia, con calidad de producción.
      </p>
      <div class="hero-ctas">
        <a href="#contacto" class="btn btn-primary">Solicita tu proyecto →</a>
        <a href="#servicios" class="btn btn-outline">Ver servicios</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">2-3</span>
          <span class="stat-label">semanas de entrega</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">+20</span>
          <span class="stat-label">años de experiencia</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">100%</span>
          <span class="stat-label">remote-first</span>
        </div>
      </div>
    </div>
  </section>

  <!-- PROPUESTA DE VALOR -->
  <section id="valor">
    <div class="container">
      <p class="section-label">Por qué Forja Labs</p>
      <h2 class="section-title">Cuatro ventajas que no encontrarás<br />en una consultora tradicional</h2>
      <div class="cards-grid">
        <div class="card">
          <div class="card-icon">⚡</div>
          <h3>Velocidad real</h3>
          <p>Sin procesos lentos ni reuniones infinitas. Entregamos en semanas lo que otros tardan meses.</p>
        </div>
        <div class="card">
          <div class="card-icon">💰</div>
          <h3>Costo justo</h3>
          <p>El workforce AI reduce costos operativos dramáticamente. Pagas por resultado, no por horas de reunión.</p>
        </div>
        <div class="card">
          <div class="card-icon">🎯</div>
          <h3>Calidad de producción</h3>
          <p>Agentes especializados + arquitectura senior. Código limpio, documentado y escalable desde el día uno.</p>
        </div>
        <div class="card">
          <div class="card-icon">🤖</div>
          <h3>Auto-corrección de bugs</h3>
          <p>Tu software se auto corrige. IA detecta y reporta problemas antes que tú. Menos bugs en producción.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS / PRECIOS -->
  <section id="servicios">
    <div class="container">
      <p class="section-label">Servicios</p>
      <h2 class="section-title">Precios por proyecto.<br />Personalizados para ti.</h2>
      <p class="section-desc">No hay tarifas estándar. Cada proyecto es único. Cuéntanos qué necesitas y te respondemos con una propuesta ajustada a tu alcance.</p>

      <div class="pricing-grid pricing-two">
        <!-- Propuesta Personalizada -->
        <div class="pricing-card featured single-price">
          <div class="pricing-badge-popular">Hablemos de tu proyecto</div>
          <div class="pricing-badge gold">⭐ Software a Medida</div>
          <p class="pricing-desc">Plataformas escalables, APIs robustas, dashboards complejos — lo que necesites. Precio justo según alcance real.</p>
          <ul class="pricing-list">
            <li>✓ Apps fullstack MVP y producción</li>
            <li>✓ APIs REST y microservicios</li>
            <li>✓ Dashboards y reportería</li>
            <li>✓ Autenticación y roles</li>
            <li>✓ Documentación completa</li>
            <li>✓ Deploy y soporte post-entrega</li>
          </ul>

          <div class="service-add">
            <p class="service-add-label">Servicios adicionales opcionales:</p>
            <div class="service-item">
              <span class="service-name">LiveCare Premium</span>
              <p class="service-desc">Soporte prioritario, mantenimiento incluido y actualizaciones continuas.</p>
            </div>
          </div>

          <a href="#contacto" class="btn btn-primary">Solicita tu proyecto →</a>
        </div>

        <!-- AIGEN Card -->
        <div class="pricing-card featured aigen-card">
          <div class="pricing-badge-popular aigen-popular">🔍 Análisis de Código</div>
          <div class="pricing-badge blue">💎 AIGEN — Análisis Inteligente</div>
          <p class="pricing-desc">Detecta problemas, identifica riesgos y obtén un plan de modernización en minutos. Sin código invasivo.</p>
          <ul class="pricing-list aigen-list">
            <li>✓ 47+ issues detectados</li>
            <li>✓ Stack completo identificado</li>
            <li>✓ Integraciones auditadas</li>
            <li>✓ Plan prioritizado</li>
          </ul>
          <a href="/servicios/aigen" class="btn btn-blue-forja">Analizar código →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESO -->
  <section id="proceso">
    <div class="container">
      <p class="section-label">Cómo trabajamos</p>
      <h2 class="section-title">Tres pasos.<br />De la idea a producción.</h2>
      <div class="steps">
        <div class="step">
          <div class="step-num">01</div>
          <div class="step-content">
            <h3>Brief & cotización</h3>
            <p>Nos cuentas qué necesitas. En 24 horas tienes propuesta técnica y precio fijo. Sin compromiso.</p>
          </div>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <div class="step-num">02</div>
          <div class="step-content">
            <h3>Desarrollo iterativo</h3>
            <p>Construimos rápido con revisiones cortas. Ves avances reales cada pocos días, no en meses.</p>
          </div>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <div class="step-num">03</div>
          <div class="step-content">
            <h3>Entrega & soporte</h3>
            <p>Deploy en producción, documentación completa y soporte post-entrega incluido.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NOSOTROS -->
  <section id="nosotros">
    <div class="container nosotros-inner">
      <div class="nosotros-text">
        <p class="section-label">Sobre Forja Labs</p>
        <h2 class="section-title">Experiencia senior. Velocidad de startup. Inteligencia artificial real.</h2>
        <p>Forja Labs nació de una convicción: el software a medida no tiene que ser lento, caro, ni mediocre.</p>
        <p>Fundada por Luis Núñez — ingeniero informático con más de 21 años en tecnología, arquitecto senior, co-fundador de docta.io — y un equipo de agentes IA especializados, cada uno con un rol definido, personalidad y capacidad de ejecución.</p>
        <h3>La diferencia: Agentes, no chatbots.</h3>
        <p>No construimos herramientas de "productividad individual". Construimos equipos de IA que viven en tu arquitectura. Que consumen eventos. Que toman decisiones. Que corrigen bugs antes que tú los veas.</p>
        <h3>Filosofía</h3>
        <ul>
          <li>Resultados antes que proceso: Lo que funciona hoy es mejor que lo perfecto en 6 meses</li>
          <li>Autonomía real: Los agentes ejecutan dentro de límites claros</li>
          <li>Documentación como código: Tu software es transferible y mantenible</li>
          <li>IA como multiplicador: Potenciamos ingeniería, no la reemplazamos</li>
        </ul>
        <hr />
        <p>Forja Labs no es una consultora. Es un equipo híbrido que construye software como debería construirse en 2026.</p>
        <p>Hecho en Chile. Con inteligencia artificial. Con propósito.</p>
      </div>
      <div class="nosotros-team">
        <h3>El equipo</h3>
        <div class="org-chart">
          <!-- CEO -->
          <div class="org-level ceo-level">
            <div class="org-node ceo">
              <span class="org-emoji">✨</span>
              <strong>CEO</strong>
              <span class="org-name">Aurora</span>
            </div>
          </div>

          <!-- Connector vertical CEO → managers -->
          <div class="org-connector-v"></div>

          <!-- Horizontal bar -->
          <div class="org-connector-h-wrap">
            <div class="org-connector-h"></div>
          </div>

          <!-- 4 Managers level -->
          <div class="org-level managers-level">
            <div class="org-branch">
              <div class="org-connector-v short"></div>
              <div class="org-node manager">
                <strong>Social Media<br/>Manager</strong>
              </div>
            </div>
            <div class="org-branch">
              <div class="org-connector-v short"></div>
              <div class="org-node manager">
                <strong>Account<br/>Manager</strong>
              </div>
            </div>
            <div class="org-branch">
              <div class="org-connector-v short"></div>
              <div class="org-node manager">
                <strong>Project<br/>Manager</strong>
              </div>
            </div>
            <div class="org-branch">
              <div class="org-connector-v short"></div>
              <div class="org-node manager">
                <strong>Operations<br/>Manager</strong>
              </div>
            </div>
          </div>

          <!-- Sub-nodes level (aligned with their parent managers via same 4-col grid) -->
          <div class="org-level subnodes-level">
            <div class="org-branch empty-branch"></div>
            <div class="org-branch empty-branch"></div>
            <div class="org-branch">
              <!-- Sub: Dev Team -->
              <div class="org-connector-v short"></div>
              <div class="org-node sub-node">
                <strong>Development<br/>Team</strong>
              </div>
            </div>
            <div class="org-branch">
              <!-- Sub: DevOps Agent -->
              <div class="org-connector-v short"></div>
              <div class="org-node sub-node">
                <strong>DevOps<br/>Agent</strong>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACTO -->
  <section id="contacto">
    <div class="container">
      <p class="section-label">Contacto</p>
      <h2 class="section-title">¿Tienes un proyecto?<br />Hablemos.</h2>
      <p class="section-desc">Cuéntanos qué necesitas y te respondemos en menos de 24 horas con una propuesta concreta.</p>

      <form id="contactForm" class="contact-form">
        <div class="form-row">
          <div class="form-group">
            <label for="nombre">Nombre</label>
            <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="tu@empresa.com" required />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="telefono">Teléfono (opcional)</label>
            <input type="tel" id="telefono" name="telefono" placeholder="+56 9 XXXX XXXX" />
          </div>
          <div class="form-group">
            <label for="asunto">Asunto</label>
            <input type="text" id="asunto" name="asunto" placeholder="Ej: API REST para mi startup" required />
          </div>
        </div>
        <div class="form-group">
          <label for="mensaje">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="5" placeholder="Describe tu proyecto: qué hace, para qué, en qué tecnología si tienes preferencia..." required minlength="10"></textarea>
        </div>

        <!-- Feedback Messages -->
        <div id="formMessage" class="form-message" style="display: none;"></div>

        <button type="submit" id="submitBtn" class="btn btn-primary">
          <span id="submitText">Enviar solicitud →</span>
          <span id="submitLoading" style="display: none;">Enviando...</span>
        </button>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById('contactForm');
    const messageDiv = document.getElementById('formMessage');
    const submitBtn = document.getElementById('submitBtn');
    const submitText = document.getElementById('submitText');
    const submitLoading = document.getElementById('submitLoading');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Reset message
      messageDiv.style.display = 'none';
      messageDiv.className = 'form-message';

      // Get form data
      const nombre = document.getElementById('nombre').value.trim();
      const email = document.getElementById('email').value.trim();
      const telefono = document.getElementById('telefono').value.trim();
      const asunto = document.getElementById('asunto').value.trim();
      const mensaje = document.getElementById('mensaje').value.trim();

      // Client-side validation
      if (!nombre) {
        showMessage('Nombre requerido', 'error');
        return;
      }
      if (!email || !isValidEmail(email)) {
        showMessage('Email inválido', 'error');
        return;
      }
      if (!asunto) {
        showMessage('Asunto requerido', 'error');
        return;
      }
      if (!mensaje || mensaje.length < 10) {
        showMessage('Mensaje debe tener al menos 10 caracteres', 'error');
        return;
      }

      // Set loading state
      submitBtn.disabled = true;
      submitText.style.display = 'none';
      submitLoading.style.display = 'inline';

      try {
        const response = await fetch('/.netlify/functions/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ nombre, email, telefono, asunto, mensaje }),
        });

        const result = await response.json();

        if (result.success) {
          showMessage(result.message, 'success');
          form.reset();
        } else {
          showMessage(result.error || 'Error al enviar. Intenta de nuevo.', 'error');
        }
      } catch (err) {
        showMessage('Error al enviar. Verifica tu conexión.', 'error');
        console.error('Form submission error:', err);
      } finally {
        submitBtn.disabled = false;
        submitText.style.display = 'inline';
        submitLoading.style.display = 'none';
      }
    });

    function isValidEmail(email) {
      const regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return regex.test(email);
    }

    function showMessage(message, type) {
      messageDiv.textContent = message;
      messageDiv.className = `form-message form-message-${type}`;
      messageDiv.style.display = 'block';
      messageDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  </script>

  <!-- FOOTER -->
  <footer>
    <div class="container footer-inner">
      <span class="logo">⚒ Forja Labs</span>
      <span class="footer-copy">© 2026 Forja Labs. Hecho con IA en Chile 🇨🇱</span>
      <div class="footer-links">
        <a href="mailto:hola@forjalabs.cl">hola@forjalabs.cl</a>
        <a href="https://instagram.com/forjalabs" target="_blank" rel="noopener noreferrer" class="social-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          Instagram
        </a>
        <a href="https://tiktok.com/@forjalabs" target="_blank" rel="noopener noreferrer" class="social-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.27 8.27 0 004.84 1.55V6.79a4.85 4.85 0 01-1.07-.1z"/></svg>
          TikTok
        </a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* NAV */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .btn-sm {
    padding: 0.55rem 1.25rem;
    font-size: 0.9rem;
  }

  /* HERO */
  #hero {
    padding: 7rem 0 5rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-badge {
    display: inline-block;
    background: rgba(245, 158, 11, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.3);
    color: var(--accent);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  #hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .accent {
    color: var(--accent);
  }

  .hero-desc {
    font-size: 1.2rem;
    color: var(--text-muted);
    max-width: 600px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3.5rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .stat-num {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
  }

  /* CARDS PROPUESTA DE VALOR */
  #valor {
    border-bottom: 1px solid var(--border);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .card:hover {
    border-color: var(--accent);
    background: var(--bg-card-hover);
  }

  .card-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .card h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .card p {
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* PRICING */
  #servicios {
    border-bottom: 1px solid var(--border);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
    align-items: start;
  }

  .pricing-grid.pricing-single {
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .pricing-grid.pricing-two {
    grid-template-columns: repeat(2, 1fr);
    max-width: 860px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .pricing-grid.pricing-two {
      grid-template-columns: 1fr;
      max-width: 500px;
    }
  }

  .pricing-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    position: relative;
    transition: border-color 0.2s;
  }

  .pricing-card.featured {
    border-color: var(--accent);
  }

  .pricing-card.single-price {
    box-shadow: 0 0 40px rgba(245, 158, 11, 0.12);
  }

  .pricing-badge-popular {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: #000;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.9rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .pricing-badge {
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .pricing-badge.gold { color: var(--accent); }
  .pricing-badge.green { color: var(--green); }
