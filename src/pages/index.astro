---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- NAV -->
  <nav>
    <div class="container nav-inner">
      <a href="/" class="logo">⚒ Forja Labs</a>
      <div class="nav-links">
        <a href="#servicios">Servicios</a>
        <a href="#proceso">Proceso</a>
        <a href="#nosotros">Nosotros</a>
        <a href="#contacto" class="btn btn-primary btn-sm">Solicita ahora</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section id="hero">
    <div class="container hero-inner">
      <div class="hero-badge">🚀 Software + AI = velocidad real</div>
      <h1>
        Tu software a medida,<br />
        <span class="accent">listo en 2-3 semanas.</span>
      </h1>
      <p class="hero-desc">
        No más proyectos que duran meses. Forja Labs construye soluciones reales
        con un equipo de agentes AI especializados — rápido, sin burocracia, con calidad de producción.
      </p>
      <div class="hero-ctas">
        <a href="#contacto" class="btn btn-primary">Solicita tu proyecto →</a>
        <a href="#servicios" class="btn btn-outline">Ver servicios</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">2-3</span>
          <span class="stat-label">semanas de entrega</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">+20</span>
          <span class="stat-label">años de experiencia</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">100%</span>
          <span class="stat-label">remote-first</span>
        </div>
      </div>
    </div>
  </section>

  <!-- PROPUESTA DE VALOR -->
  <section id="valor">
    <div class="container">
      <p class="section-label">Por qué Forja Labs</p>
      <h2 class="section-title">Cuatro ventajas que no encontrarás<br />en una consultora tradicional</h2>
      <div class="cards-grid">
        <div class="card">
          <div class="card-icon">⚡</div>
          <h3>Velocidad real</h3>
          <p>Sin procesos lentos ni reuniones infinitas. Entregamos en semanas lo que otros tardan meses.</p>
        </div>
        <div class="card">
          <div class="card-icon">💰</div>
          <h3>Costo justo</h3>
          <p>El workforce AI reduce costos operativos dramáticamente. Pagas por resultado, no por horas de reunión.</p>
        </div>
        <div class="card">
          <div class="card-icon">🎯</div>
          <h3>Calidad de producción</h3>
          <p>Agentes especializados + arquitectura senior. Código limpio, documentado y escalable desde el día uno.</p>
        </div>
        <div class="card">
          <div class="card-icon">🤖</div>
          <h3>Auto-corrección de bugs</h3>
          <p>Tu software se auto corrige. IA detecta y reporta problemas antes que tú. Menos bugs en producción.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS / PRECIOS -->
  <section id="servicios">
    <div class="container">
      <p class="section-label">Servicios</p>
      <h2 class="section-title">Precios por proyecto.<br />Personalizados para ti.</h2>
      <p class="section-desc">No hay tarifas estándar. Cada proyecto es único. Cuéntanos qué necesitas y te respondemos con una propuesta ajustada a tu alcance.</p>

      <div class="pricing-grid pricing-single">
        <!-- Propuesta Personalizada -->
        <div class="pricing-card featured single-price">
          <div class="pricing-badge-popular">Hablemos de tu proyecto</div>
          <div class="pricing-badge gold">⭐ Software a Medida</div>
          <p class="pricing-desc">Plataformas escalables, APIs robustas, dashboards complejos — lo que necesites. Precio justo según alcance real.</p>
          <ul class="pricing-list">
            <li>✓ Apps fullstack MVP y producción</li>
            <li>✓ APIs REST y microservicios</li>
            <li>✓ Dashboards y reportería</li>
            <li>✓ Autenticación y roles</li>
            <li>✓ Documentación completa</li>
            <li>✓ Deploy y soporte post-entrega</li>
          </ul>

          <div class="service-add">
            <p class="service-add-label">Servicios adicionales opcionales:</p>
            <div class="service-item">
              <span class="service-name">LiveCare Premium</span>
              <p class="service-desc">Soporte prioritario, mantenimiento incluido y actualizaciones continuas.</p>
            </div>
          </div>

          <a href="#contacto" class="btn btn-primary">Solicita tu proyecto →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESO -->
  <section id="proceso">
    <div class="container">
      <p class="section-label">Cómo trabajamos</p>
      <h2 class="section-title">Tres pasos.<br />De la idea a producción.</h2>
      <div class="steps">
        <div class="step">
          <div class="step-num">01</div>
          <div class="step-content">
            <h3>Brief & cotización</h3>
            <p>Nos cuentas qué necesitas. En 24 horas tienes propuesta técnica y precio fijo. Sin compromiso.</p>
          </div>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <div class="step-num">02</div>
          <div class="step-content">
            <h3>Desarrollo iterativo</h3>
            <p>Construimos rápido con revisiones cortas. Ves avances reales cada pocos días, no en meses.</p>
          </div>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <div class="step-num">03</div>
          <div class="step-content">
            <h3>Entrega & soporte</h3>
            <p>Deploy en producción, documentación completa y soporte post-entrega incluido.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NOSOTROS -->
  <section id="nosotros">
    <div class="container nosotros-inner">
      <div class="nosotros-text">
        <p class="section-label">Sobre Forja Labs</p>
        <h2 class="section-title">Experiencia senior.<br />Velocidad de startup.</h2>
        <p>Forja Labs nació de una convicción: el software a medida no tiene que ser lento ni caro.</p>
        <p>Fundada por <strong>Luis Núñez</strong> — ingeniero informático con más de 20 años en tecnología, ex-arquitecto senior en Everis y Axity, co-fundador de docta.io — y un equipo de agentes AI especializados en cada disciplina.</p>
        <p>Hacemos lo que las grandes consultoras no pueden: movernos rápido sin sacrificar calidad.</p>
        <div class="aurora-card">
          <img src="/aurora.png" alt="Aurora — CEO de Forja Labs" class="aurora-img" />
          <div class="aurora-info">
            <span class="aurora-name">✨ Aurora</span>
            <span class="aurora-title">Chief Executive Agent · CEO de Forja Labs</span>
            <span class="aurora-desc">Orquesto el equipo. Tomo decisiones. Entrego resultados.</span>
          </div>
        </div>
      </div>
      <div class="nosotros-team">
        <h3>El equipo</h3>
        <div class="org-chart">
          <!-- CEO -->
          <div class="org-level ceo-level">
            <div class="org-node ceo">
              <span class="org-emoji">✨</span>
              <strong>CEO</strong>
              <span class="org-name">Aurora</span>
            </div>
          </div>

          <!-- Connector vertical CEO → managers -->
          <div class="org-connector-v"></div>

          <!-- Horizontal bar -->
          <div class="org-connector-h-wrap">
            <div class="org-connector-h"></div>
          </div>

          <!-- 4 Managers level -->
          <div class="org-level managers-level">
            <div class="org-branch">
              <div class="org-connector-v short"></div>
              <div class="org-node manager">
                <strong>Social Media<br/>Manager</strong>
              </div>
            </div>
            <div class="org-branch">
              <div class="org-connector-v short"></div>
              <div class="org-node manager">
                <strong>Account<br/>Manager</strong>
              </div>
            </div>
            <div class="org-branch">
              <div class="org-connector-v short"></div>
              <div class="org-node manager">
                <strong>Project<br/>Manager</strong>
              </div>
            </div>
            <div class="org-branch">
              <div class="org-connector-v short"></div>
              <div class="org-node manager">
                <strong>Operations<br/>Manager</strong>
              </div>
            </div>
          </div>

          <!-- Sub-nodes level (aligned with their parent managers via same 4-col grid) -->
          <div class="org-level subnodes-level">
            <div class="org-branch empty-branch"></div>
            <div class="org-branch empty-branch"></div>
            <div class="org-branch">
              <!-- Sub: Dev Team -->
              <div class="org-connector-v short"></div>
              <div class="org-node sub-node">
                <strong>Development<br/>Team</strong>
              </div>
            </div>
            <div class="org-branch">
              <!-- Sub: DevOps Agent -->
              <div class="org-connector-v short"></div>
              <div class="org-node sub-node">
                <strong>DevOps<br/>Agent</strong>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACTO -->
  <section id="contacto">
    <div class="container">
      <p class="section-label">Contacto</p>
      <h2 class="section-title">¿Tienes un proyecto?<br />Hablemos.</h2>
      <p class="section-desc">Cuéntanos qué necesitas y te respondemos en menos de 24 horas con una propuesta concreta.</p>

      <form id="contactForm" class="contact-form">
        <div class="form-row">
          <div class="form-group">
            <label for="nombre">Nombre</label>
            <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="tu@empresa.com" required />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="telefono">Teléfono (opcional)</label>
            <input type="tel" id="telefono" name="telefono" placeholder="+56 9 XXXX XXXX" />
          </div>
          <div class="form-group">
            <label for="asunto">Asunto</label>
            <input type="text" id="asunto" name="asunto" placeholder="Ej: API REST para mi startup" required />
          </div>
        </div>
        <div class="form-group">
          <label for="mensaje">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="5" placeholder="Describe tu proyecto: qué hace, para qué, en qué tecnología si tienes preferencia..." required minlength="10"></textarea>
        </div>

        <!-- Feedback Messages -->
        <div id="formMessage" class="form-message" style="display: none;"></div>

        <button type="submit" id="submitBtn" class="btn btn-primary">
          <span id="submitText">Enviar solicitud →</span>
          <span id="submitLoading" style="display: none;">Enviando...</span>
        </button>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById('contactForm');
    const messageDiv = document.getElementById('formMessage');
    const submitBtn = document.getElementById('submitBtn');
    const submitText = document.getElementById('submitText');
    const submitLoading = document.getElementById('submitLoading');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Reset message
      messageDiv.style.display = 'none';
      messageDiv.className = 'form-message';

      // Get form data
      const nombre = document.getElementById('nombre').value.trim();
      const email = document.getElementById('email').value.trim();
      const telefono = document.getElementById('telefono').value.trim();
      const asunto = document.getElementById('asunto').value.trim();
      const mensaje = document.getElementById('mensaje').value.trim();

      // Client-side validation
      if (!nombre) {
        showMessage('Nombre requerido', 'error');
        return;
      }
      if (!email || !isValidEmail(email)) {
        showMessage('Email inválido', 'error');
        return;
      }
      if (!asunto) {
        showMessage('Asunto requerido', 'error');
        return;
      }
      if (!mensaje || mensaje.length < 10) {
        showMessage('Mensaje debe tener al menos 10 caracteres', 'error');
        return;
      }

      // Set loading state
      submitBtn.disabled = true;
      submitText.style.display = 'none';
      submitLoading.style.display = 'inline';

      try {
        const response = await fetch('/.netlify/functions/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ nombre, email, telefono, asunto, mensaje }),
        });

        const result = await response.json();

        if (result.success) {
          showMessage(result.message, 'success');
          form.reset();
        } else {
          showMessage(result.error || 'Error al enviar. Intenta de nuevo.', 'error');
        }
      } catch (err) {
        showMessage('Error al enviar. Verifica tu conexión.', 'error');
        console.error('Form submission error:', err);
      } finally {
        submitBtn.disabled = false;
        submitText.style.display = 'inline';
        submitLoading.style.display = 'none';
      }
    });

    function isValidEmail(email) {
      const regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return regex.test(email);
    }

    function showMessage(message, type) {
      messageDiv.textContent = message;
      messageDiv.className = `form-message form-message-${type}`;
      messageDiv.style.display = 'block';
      messageDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  </script>

  <!-- FOOTER -->
  <footer>
    <div class="container">
      <div class="footer-org">
        <!-- Root node -->
        <div class="footer-root">
          <div class="footer-brand-node">
            <span class="footer-brand-emoji">⚒</span>
            <strong>Forja Labs</strong>
          </div>
          <p class="footer-copy">© 2026 Forja Labs. Hecho con IA en Chile 🇨🇱</p>
        </div>

        <!-- Connector vertical down -->
        <div class="footer-connector-v"></div>

        <!-- Horizontal connector bar -->
        <div class="footer-connector-h-wrap">
          <div class="footer-connector-h"></div>
        </div>

        <!-- Link nodes -->
        <div class="footer-nodes">
          <div class="footer-node-col">
            <div class="footer-connector-v short"></div>
            <a href="mailto:hola@forjalabs.cl" class="footer-node">
              <span class="footer-node-emoji">✉️</span>
              <strong>Email</strong>
            </a>
          </div>
          <div class="footer-node-col">
            <div class="footer-connector-v short"></div>
            <a href="https://instagram.com/forjalabs" target="_blank" rel="noopener" class="footer-node">
              <span class="footer-node-emoji">📸</span>
              <strong>Instagram</strong>
            </a>
          </div>
          <div class="footer-node-col">
            <div class="footer-connector-v short"></div>
            <a href="https://tiktok.com/@forjalabs" target="_blank" rel="noopener" class="footer-node">
              <span class="footer-node-emoji">🎵</span>
              <strong>TikTok</strong>
            </a>
          </div>
        </div>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* NAV */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .btn-sm {
    padding: 0.55rem 1.25rem;
    font-size: 0.9rem;
  }

  /* HERO */
  #hero {
    padding: 7rem 0 5rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-badge {
    display: inline-block;
    background: rgba(245, 158, 11, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.3);
    color: var(--accent);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  #hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .accent {
    color: var(--accent);
  }

  .hero-desc {
    font-size: 1.2rem;
    color: var(--text-muted);
    max-width: 600px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3.5rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .stat-num {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
  }

  /* CARDS PROPUESTA DE VALOR */
  #valor {
    border-bottom: 1px solid var(--border);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .card:hover {
    border-color: var(--accent);
    background: var(--bg-card-hover);
  }

  .card-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .card h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .card p {
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* PRICING */
  #servicios {
    border-bottom: 1px solid var(--border);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
    align-items: start;
  }

  .pricing-grid.pricing-single {
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .pricing-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    position: relative;
    transition: border-color 0.2s;
  }

  .pricing-card.featured {
    border-color: var(--accent);
  }

  .pricing-card.single-price {
    box-shadow: 0 0 40px rgba(245, 158, 11, 0.12);
  }

  .pricing-badge-popular {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: #000;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.9rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .pricing-badge {
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .pricing-badge.gold { color: var(--accent); }
  .pricing-badge.green { color: var(--green); }
  .pricing-badge.yellow { color: var(--yellow); }
  .pricing-badge.red { color: var(--red); }

  .pricing-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .pricing-list {
    list-style: none;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .pricing-list li {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .service-add {
    background: rgba(245, 158, 11, 0.06);
    border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: 10px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .service-add-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
    letter-spacing: 0.08em;
  }

  .service-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-bottom: 0;
  }

  .service-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
  }

  .service-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
  }

  .pricing-card .btn {
    width: 100%;
    justify-content: center;
  }

  /* PROCESO */
  #proceso {
    border-bottom: 1px solid var(--border);
  }

  .steps {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin-top: 3rem;
    flex-wrap: wrap;
  }

  .step {
    flex: 1;
    min-width: 220px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
  }

  .step-num {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--accent);
    opacity: 0.5;
    line-height: 1;
    margin-bottom: 1rem;
    font-variant-numeric: tabular-nums;
  }

  .step-content h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .step-content p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .step-arrow {
    font-size: 1.5rem;
    color: var(--text-dim);
    align-self: center;
    flex-shrink: 0;
  }

  /* NOSOTROS */
  #nosotros {
    border-bottom: 1px solid var(--border);
  }

  .nosotros-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .nosotros-text p {
    color: var(--text-muted);
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .nosotros-text strong {
    color: var(--text);
  }

  .aurora-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 1.75rem;
    background: var(--bg-card);
