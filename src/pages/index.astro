  <script>
    const form = document.getElementById('contactForm');
    const messageDiv = document.getElementById('formMessage');
    const submitBtn = document.getElementById('submitBtn');
    const submitText = document.getElementById('submitText');
    const submitLoading = document.getElementById('submitLoading');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Reset message
      messageDiv.style.display = 'none';
      messageDiv.className = 'form-message';

      // Get form data
      const nombre = document.getElementById('nombre').value.trim();
      const email = document.getElementById('email').value.trim();
      const telefono = document.getElementById('telefono').value.trim();
      const asunto = document.getElementById('asunto').value.trim();
      const mensaje = document.getElementById('mensaje').value.trim();

      // Client-side validation
      if (!nombre) {
        showMessage('Nombre requerido', 'error');
        return;
      }
      if (!email || !isValidEmail(email)) {
        showMessage('Email inválido', 'error');
        return;
      }
      if (!asunto) {
        showMessage('Asunto requerido', 'error');
        return;
      }
      if (!mensaje || mensaje.length < 10) {
        showMessage('Mensaje debe tener al menos 10 caracteres', 'error');
        return;
      }

      // Set loading state
      submitBtn.disabled = true;
      submitText.style.display = 'none';
      submitLoading.style.display = 'inline';

      try {
        const response = await fetch('/.netlify/functions/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ nombre, email, telefono, asunto, mensaje }),
        });

        const result = await response.json();

        if (result.success) {
          showMessage(result.message, 'success');
          form.reset();
        } else {
          showMessage(result.error || 'Error al enviar. Intenta de nuevo.', 'error');
        }
      } catch (err) {
        showMessage('Error al enviar. Verifica tu conexión.', 'error');
        console.error('Form submission error:', err);
      } finally {
        submitBtn.disabled = false;
        submitText.style.display = 'inline';
        submitLoading.style.display = 'none';
      }
    });

    function isValidEmail(email) {
      const regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return regex.test(email);
    }

    function showMessage(message, type) {
      messageDiv.textContent = message;
      messageDiv.className = `form-message form-message-${type}`;
      messageDiv.style.display = 'block';
      messageDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  </script>

